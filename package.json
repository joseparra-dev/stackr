{
  "name": "stackr",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:prod": "ng build --configuration=production",
    "sentry:sourcemaps": "node scripts/sentry-upload-sourcemaps.mjs",
    "build:prod:sentry": "pnpm build:prod && pnpm sentry:sourcemaps",
    "watch": "ng build --watch --configuration development",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "lint": "eslint . --max-warnings=0 && node scripts/check-template-i18n.mjs",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,html,css,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,html,css,json}\"",
    "prepare": "husky",
    "db:push": "supabase db push",
    "db:reset": "supabase db reset",
    "db:diff": "supabase db diff",
    "type-check": "tsc --noEmit"
  },
  "private": true,
  "packageManager": "pnpm@11.1.2",
  "dependencies": {
    "@angular/cdk": "^21.2.12",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/localize": "^21.2.16",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@lucide/angular": "^1.16.0",
    "@sentry/angular": "^10.56.0",
    "@supabase/supabase-js": "^2.106.1",
    "@tailwindcss/postcss": "^4.3.0",
    "apexcharts": "^5.12.0",
    "ng-apexcharts": "^2.4.0",
    "postcss": "^8.5.15",
    "rxjs": "~7.8.0",
    "tailwindcss": "^4.3.0",
    "tslib": "^2.3.0",
    "zone.js": "^0.16.2"
  },
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "^2.5.1",
    "@analogjs/vitest-angular": "^2.5.1",
    "@angular/build": "^21.2.12",
    "@angular/cli": "^21.2.12",
    "@angular/compiler-cli": "^21.2.0",
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@ngx-env/builder": "^21.0.1",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.1",
    "@vitest/ui": "^4.1.7",
    "angular-eslint": "^21.4.0",
    "@sentry/cli": "^2.58.4",
    "axe-core": "^4.12.0",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^17.0.5",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.59.4",
    "vitest": "^4.1.7"
  }
}
