# Public env (cliente puede leer)
NG_APP_SUPABASE_URL=https://your-project.supabase.co
NG_APP_SUPABASE_ANON_KEY=eyJ...

# CoinGecko (sin auth en free tier)
NG_APP_COINGECKO_BASE_URL=https://api.coingecko.com/api/v3

# Sentry (client — optional locally)
NG_APP_SENTRY_DSN=
# Set on Vercel to VERCEL_GIT_COMMIT_SHA for release tracking
NG_APP_SENTRY_RELEASE=

# Sentry source maps upload (CI / Vercel build only — never commit real tokens)
SENTRY_ORG=
SENTRY_PROJECT=stackr
SENTRY_AUTH_TOKEN=
# Use when the DSN host is ingest.us.sentry.io (US region orgs)
SENTRY_URL=https://us.sentry.io

# Environment
NG_APP_ENV=development