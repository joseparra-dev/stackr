# Committed baseline (NO secrets). Guarantees every NG_APP_* key is defined at
# build time so @ngx-env/builder always inlines a literal and the app never
# crashes on a missing var. Override locally via .env.local (gitignored) and in
# production via the hosting provider's environment variables (e.g. Vercel).

# Public, non-secret defaults.
NG_APP_COINGECKO_BASE_URL=https://api.coingecko.com/api/v3
# Demo API key (free tier). Empty = public API (very low rate limit).
# Get yours at https://www.coingecko.com/en/developers/dashboard
NG_APP_COINGECKO_API_KEY=

# Filled by .env.local (dev) or Vercel env vars (prod). Empty here on purpose:
# if a provider forgets to set them the app fails closed with a clear error
# instead of a blank screen.
NG_APP_SUPABASE_URL=
NG_APP_SUPABASE_ANON_KEY=

# Optional. Empty disables Sentry.
NG_APP_SENTRY_DSN=

NG_APP_ENV=production
